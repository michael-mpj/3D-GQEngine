# 3D Geospatial Quantum Engine - Environment Configuration
# Copy this file to .env and fill in real values before deployment.

# Google Tag Manager container ID (e.g. GTM-XXXXXX)
VITE_GTM_ID=GTM-NKQ8C9HH

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA4_ID=G-V8RF39YJC5

# Production site URL (used for OG tags, canonical, sitemap)
VITE_SITE_URL=https://3dgqengine.mikempj.com

# Optional: Map tile provider URL override
# VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Optional: Enable debug telemetry logging
# VITE_DEBUG_ANALYTICS=true
