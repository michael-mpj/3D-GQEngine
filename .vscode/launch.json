        {"name":"Python Debugger: Remote Attach","type":"debugpy","request":"attach","connect":{"host":"localhost","port":5678},"pathMappings":[{"localRoot":"${workspaceFolder}","remoteRoot":"."}]},
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
